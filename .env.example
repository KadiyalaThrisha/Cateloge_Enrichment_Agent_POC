# Required for Groq (family names, variant axes, color vision when used): set in env or .env at repo root.
# GROQ_API_KEY=

APP_NAME=Catalog Enrichment Microservice
APP_ENV=dev
API_PREFIX=/api/v1
# Your n8n or taxonomy service URL (do not commit real internal URLs in tracked docs if policy forbids it).
TAXONOMY_WEBHOOK_URL=https://your-n8n-host.example/webhook/your-taxonomy-path
# Items per request to n8n (sequential: next chunk after previous returns). Default 5. Use 0 for one request for the whole batch.
TAXONOMY_WEBHOOK_BATCH_SIZE=5
# Seconds per webhook POST (each chunk).
TAXONOMY_WEBHOOK_TIMEOUT=20
TAXONOMY_VERIFY_SSL=false
GROUPING_LLM_FALLBACK_THRESHOLD=0.75
# VARIANT_AXES_LLM_ENABLED=true

# Comma-separated browser origins allowed to call the API (CORS). Empty = dev defaults (Vite ports).
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Family display name: llm_only (default) uses Groq for every SKU; hybrid = regex title first, LLM if confidence low.
# GROUPING_FAMILY_NAME_SOURCE=hybrid
# Merge SKUs with the same family when taxonomy has no category_id (uses word-sorted family key). false = one group per SKU.
# GROUPING_MERGE_BY_FAMILY_NAME_KEY=false

# Streamlit dashboard: default API base (no trailing slash). FastAPI backend is ON by default.
CATALOG_API_BASE_URL=http://127.0.0.1:8001
# Set to false to open the dashboard with local Supervisor instead of HTTP.
# CATALOG_USE_FASTAPI=false

# FastAPI "Run Enrichment": split into multiple POSTs (items per request). 0 = single request.
# Use 25–100 for large merchant feeds to reduce taxonomy timeouts. Grouping merges only within each chunk.
# CATALOG_ENRICHMENT_CHUNK_SIZE=50

